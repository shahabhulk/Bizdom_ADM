<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_sheet_form_done_button" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.done.button</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_submit_sheet']" position="before">
                <button name="action_force_done"
                        string="Done"
                        type="object"
                        class="oe_highlight btn-success"
                        invisible="state in ('done', 'cancel')"
                        confirm="This will approve, create journal entries, post, and register payment. Continue?"
                        data-hotkey="d"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_expense_form_department" model="ir.ui.view">
        <field name="name">hr.expense.form.department</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id'][2]" position="after">
                <field name="department_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_department" model="ir.ui.view">
        <field name="name">account.move.line.tree.department</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="department_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_form_department" model="ir.ui.view">
        <field name="name">account.move.line.form.department</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='partner_id']]" position="inside">
                <field name="department_id" />
            </xpath>
        </field>
    </record>
</odoo>
